{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Patchbook",
  "scopeName": "source.patchbook",
  "patterns": [
    { "include": "#comment" },
    { "include": "#voice" },
    { "include": "#connection" },
    { "include": "#parameter-single" },
    { "include": "#parameter-module-header" },
    { "include": "#parameter-multi-line" }
  ],
  "repository": {
    "comment": {
      "match": "^\\s*//.*$",
      "name": "comment.line.double-slash.patchbook"
    },
    "voice": {
      "match": "^([A-Z][A-Z0-9 ]*):$",
      "captures": {
        "1": { "name": "entity.name.section.voice.patchbook" }
      }
    },
    "connection": {
      "match": "^\\s*-\\s+(.+?)\\s*(\\()(.+?)(\\))\\s*(->|>>|p>|g>|t>|c>)\\s+(.+?)\\s*(\\()(.+?)(\\))\\s*(\\[.*\\])?\\s*$",
      "captures": {
        "1": { "name": "entity.name.type.module.output.patchbook" },
        "2": { "name": "punctuation.parenthesis.open.patchbook" },
        "3": { "name": "variable.parameter.port.output.patchbook" },
        "4": { "name": "punctuation.parenthesis.close.patchbook" },
        "5": { "name": "keyword.operator.connection.patchbook" },
        "6": { "name": "entity.name.type.module.input.patchbook" },
        "7": { "name": "punctuation.parenthesis.open.patchbook" },
        "8": { "name": "variable.parameter.port.input.patchbook" },
        "9": { "name": "punctuation.parenthesis.close.patchbook" },
        "10": { "name": "support.other.arguments.patchbook" }
      }
    },
    "parameter-single": {
      "match": "^\\s*\\*\\s+(.+?):\\s+(.+)$",
      "captures": {
        "1": { "name": "entity.name.tag.module.patchbook" },
        "2": {
          "patterns": [
            {
              "match": "([^=|]+)\\s*=\\s*([^|]+)",
              "captures": {
                "1": { "name": "variable.other.parameter-name.patchbook" },
                "2": { "name": "constant.numeric.parameter-value.patchbook" }
              }
            },
            {
              "match": "\\|",
              "name": "punctuation.separator.patchbook"
            }
          ]
        }
      }
    },
    "parameter-module-header": {
      "match": "^\\s*\\*\\s+(.+?):\\s*$",
      "captures": {
        "1": { "name": "entity.name.tag.module.patchbook" }
      }
    },
    "parameter-multi-line": {
      "match": "^\\s*\\|\\s*(.+?)\\s*=\\s*(.+)$",
      "captures": {
        "1": { "name": "variable.other.parameter-name.patchbook" },
        "2": { "name": "constant.numeric.parameter-value.patchbook" }
      }
    }
  }
}
