{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*[A-Z][A-Z0-9 ]*:$",
      "end": "^(?=\\s*[A-Z][A-Z0-9 ]*:$)"
    }
  }
}
