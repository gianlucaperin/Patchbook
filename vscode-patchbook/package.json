{
  "name": "patchbook",
  "displayName": "Patchbook",
  "description": "Syntax highlighting, autocompletion, JSON export, and graph visualization for Patchbook modular synth patches",
  "version": "0.4.0",
  "publisher": "spektroaudio",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "patchbook",
        "aliases": [
          "Patchbook",
          "patchbook"
        ],
        "extensions": [
          ".pb",
          ".patchbook"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "patchbook",
        "scopeName": "source.patchbook",
        "path": "./syntaxes/patchbook.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "patchbook.newPatch",
        "title": "Patchbook: New Patch",
        "icon": "$(new-file)",
        "shortTitle": "Patchbook Patch"
      },
      {
        "command": "patchbook.exportJSON",
        "title": "Patchbook: Export to JSON",
        "icon": "$(json)"
      },
      {
        "command": "patchbook.showGraph",
        "title": "Patchbook: Show Signal Flow Graph",
        "icon": "$(circuit-board)"
      },
      {
        "command": "patchbook.editModules",
        "title": "Patchbook: Edit Module Database"
      },
      {
        "command": "patchbook.reloadModules",
        "title": "Patchbook: Reload Module Database"
      },
      {
        "command": "patchbook.addModule",
        "title": "Patchbook: Add Module",
        "icon": "$(add)"
      },
      {
        "command": "patchbook.removeModule",
        "title": "Patchbook: Remove Module",
        "icon": "$(trash)"
      },
      {
        "command": "patchbook.graph.zoomIn",
        "title": "Patchbook Graph: Zoom In",
        "icon": "$(zoom-in)"
      },
      {
        "command": "patchbook.graph.zoomOut",
        "title": "Patchbook Graph: Zoom Out",
        "icon": "$(zoom-out)"
      },
      {
        "command": "patchbook.graph.fit",
        "title": "Patchbook Graph: Fit to View",
        "icon": "$(screen-full)"
      },
      {
        "command": "patchbook.graph.reset",
        "title": "Patchbook Graph: Reset View",
        "icon": "$(discard)"
      },
      {
        "command": "patchbook.graph.addModule",
        "title": "Patchbook Graph: Add Module",
        "icon": "$(add)"
      },
      {
        "command": "patchbook.graph.removeModule",
        "title": "Patchbook Graph: Remove Module",
        "icon": "$(trash)"
      },
      {
        "command": "patchbook.exportPDF",
        "title": "Patchbook: Export to PDF",
        "icon": "$(file-pdf)"
      }
    ],
    "menus": {
      "file/newFile": [
        {
          "command": "patchbook.newPatch",
          "group": "file"
        }
      ],
      "editor/title": [
        {
          "command": "patchbook.addModule",
          "when": "editorLangId == patchbook",
          "group": "navigation"
        },
        {
          "command": "patchbook.removeModule",
          "when": "editorLangId == patchbook",
          "group": "navigation"
        },
        {
          "command": "patchbook.exportJSON",
          "when": "editorLangId == patchbook",
          "group": "navigation"
        },
        {
          "command": "patchbook.showGraph",
          "when": "editorLangId == patchbook",
          "group": "navigation"
        },
        {
          "command": "patchbook.exportPDF",
          "when": "editorLangId == patchbook",
          "group": "navigation"
        },
        {
          "command": "patchbook.graph.zoomIn",
          "when": "activeWebviewPanelId == patchbookGraph",
          "group": "navigation@1"
        },
        {
          "command": "patchbook.graph.zoomOut",
          "when": "activeWebviewPanelId == patchbookGraph",
          "group": "navigation@2"
        },
        {
          "command": "patchbook.graph.fit",
          "when": "activeWebviewPanelId == patchbookGraph",
          "group": "navigation@3"
        },
        {
          "command": "patchbook.graph.reset",
          "when": "activeWebviewPanelId == patchbookGraph",
          "group": "navigation@4"
        },
        {
          "command": "patchbook.graph.addModule",
          "when": "activeWebviewPanelId == patchbookGraph",
          "group": "navigation@5"
        },
        {
          "command": "patchbook.graph.removeModule",
          "when": "activeWebviewPanelId == patchbookGraph && patchbook.graph.hasSelection",
          "group": "navigation@6"
        },
        {
          "command": "patchbook.exportPDF",
          "when": "activeWebviewPanelId == patchbookGraph",
          "group": "navigation@7"
        }
      ],
      "editor/context": [
        {
          "command": "patchbook.exportJSON",
          "when": "editorLangId == patchbook",
          "group": "patchbook"
        },
        {
          "command": "patchbook.showGraph",
          "when": "editorLangId == patchbook",
          "group": "patchbook"
        }
      ]
    },
    "configuration": {
      "title": "Patchbook",
      "properties": {
        "patchbook.graphDirection": {
          "type": "string",
          "default": "LR",
          "enum": [
            "LR",
            "TB"
          ],
          "description": "Graph layout direction: LR (left-to-right) or TB (top-to-bottom)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.3.0"
  }
}
